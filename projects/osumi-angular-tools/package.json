{
  "name": "@osumi/angular-tools",
  "version": "1.5.2",
  "description": "Tools to be used on Angular projects.",
  "author": "Iñigo Gorosabel",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/osumionline/Osumi-Angular-Tools/issues"
  },
  "homepage": "https://github.com/osumionline/Osumi-Angular-Tools#readme",
  "type": "module",
  "module": "./fesm2022/osumi-angular-tools.mjs",
  "types": "index.d.ts",
  "peerDependencies": {
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "rxjs": "~7.8.2"
  },
  "dependencies": {
    "@angular-devkit/schematics": "^22.0.0",
    "tslib": "^2.8.1"
  },
  "sideEffects": false,
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "schematics": "./schematics/collection.json",
  "ng-update": {
    "migrations": "./schematics/migrations/migrations.json"
  },
  "exports": {
    "./styles/dialogs.scss": {
      "sass": "./styles/dialogs.scss",
      "style": "./styles/dialogs.scss",
      "default": "./styles/dialogs.scss"
    },
    "./styles/modals.scss": {
      "sass": "./styles/modals.scss",
      "style": "./styles/modals.scss",
      "default": "./styles/modals.scss"
    },
    "./lib/styles/dialogs.scss": {
      "sass": "./styles/dialogs.scss",
      "style": "./styles/dialogs.scss",
      "default": "./styles/dialogs.scss"
    },
    "./lib/styles/modals.scss": {
      "sass": "./styles/modals.scss",
      "style": "./styles/modals.scss",
      "default": "./styles/modals.scss"
    }
  }
}
